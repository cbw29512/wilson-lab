# Purpose: Ignore build outputs, deps, secrets, OS clutter.

# Node / frontend
node_modules/
dist/
frontend/dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Env/secrets (NEVER commit)
.env
.env.*
!**/.env.example
secrets/
deploy/secrets/
*.key
*.pem

# Deployment state
deploy/backups/
deploy/.env

# Terraform state and local inputs
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!**/terraform.tfvars.example
.terraform.lock.hcl
crash.log
crash.*.log

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS
.DS_Store
Thumbs.db

# Local timestamped backups (keep out of git)
*.bak_*
