WILSON_LAB_ENVIRONMENT=development
WILSON_LAB_DATABASE_URL=sqlite:///./wilson_lab.db
WILSON_LAB_JWT_SECRET=generate-a-long-random-secret
# Production alternative: WILSON_LAB_JWT_SECRET_FILE=/run/secrets/jwt_secret
WILSON_LAB_ACCESS_TOKEN_MINUTES=30
WILSON_LAB_RUNTIME_MODE=mock
WILSON_LAB_CORS_ORIGINS=["http://localhost:5173","https://cbw29512.github.io"]
WILSON_LAB_MANAGED_LABEL=wilson-lab.managed=true
WILSON_LAB_SEED_DEMO_USERS=true
WILSON_LAB_VIEWER_USERNAME=viewer
WILSON_LAB_VIEWER_PASSWORD=replace-viewer-password
# Production alternative: WILSON_LAB_VIEWER_PASSWORD_FILE=/run/secrets/viewer_password
WILSON_LAB_ADMIN_USERNAME=admin
WILSON_LAB_ADMIN_PASSWORD=replace-admin-password
# Production alternative: WILSON_LAB_ADMIN_PASSWORD_FILE=/run/secrets/admin_password
