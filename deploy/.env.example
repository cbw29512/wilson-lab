# Public DNS name that points to the isolated cloud VM.
API_DOMAIN=api.example.com

# Numeric group ID that owns /var/run/docker.sock on the cloud VM.
# Resolve with: stat -c '%g' /var/run/docker.sock
DOCKER_GID=999

# Demo identities. Passwords are generated into deploy/secrets/ and never committed.
VIEWER_USERNAME=viewer
ADMIN_USERNAME=admin
ACCESS_TOKEN_MINUTES=30
