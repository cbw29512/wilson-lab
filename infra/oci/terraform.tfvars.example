# Copy this file to terraform.tfvars and replace every example value.
# terraform.tfvars is ignored by Git.

region              = "us-ashburn-1"
compartment_ocid    = "ocid1.compartment.oc1..replace-me"
ssh_public_key_path = "~/.ssh/id_ed25519.pub"
ssh_allowed_cidr    = "203.0.113.10/32"
api_domain          = "api.example.com"

# Recommended Always Free starting size.
instance_ocpus      = 1
instance_memory_gbs = 6
boot_volume_size_gbs = 50

# Change to 1 or 2 only when the selected availability domain has no A1 capacity.
availability_domain_index = 0
